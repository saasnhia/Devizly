# LinkedIn API credentials for auto-poster
# Copy this to .env.linkedin and fill in your values

# Get from: LinkedIn Developer Portal → Your App → Auth
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# Your LinkedIn person URN (for personal profile posting)
# Find via: https://api.linkedin.com/v2/userinfo (with your token)
LINKEDIN_PERSON_URN=urn:li:person:XXXXX

# Optional: LinkedIn organization URN (for company page posting)
# Find in your company page URL: linkedin.com/company/{id}
# LINKEDIN_ORG_URN=urn:li:organization:XXXXX

# ─── Buffer API (recommended method) ───
# Get from: https://buffer.com/developers/apps → Create App → Access Token
BUFFER_ACCESS_TOKEN=your_buffer_token_here

# Find with: node scripts/linkedin/get-buffer-profile-id.mjs
BUFFER_PROFILE_ID=your_profile_id_here
